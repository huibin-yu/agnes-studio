# Agnes Studio - Environment Configuration
# Copy this file to .env and fill in the required values

# ============================================================
# Agnes AI API Configuration
# Get your API Key from: https://platform.agnes-ai.com
# ============================================================
AGNES_API_KEY=your_agnes_api_key_here
AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# ============================================================
# Application Configuration
# ============================================================
# REQUIRED: Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Frontend base URL (for CORS)
BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================
# Database Configuration
# ============================================================
# SQLite (default, no additional setup needed)
DATABASE_URL=sqlite+aiosqlite:///./agnes_studio.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/agnes_studio

# ============================================================
# Generation Settings (optional - defaults are reasonable)
# ============================================================
IMAGE_DEFAULT_SIZE=1024x768
VIDEO_DEFAULT_FRAMES=121
VIDEO_DEFAULT_FPS=24

# ============================================================
# Pricing (credits)
# ============================================================
IMAGE_COST=1
VIDEO_COST_PER_SECOND=2
FREE_CREDITS_ON_REGISTER=12
REFERRAL_BONUS=5

# ============================================================
# Rate Limiting (requests per time window)
# ============================================================
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_GENERATE=10/hour
RATE_LIMIT_DEFAULT=60/minute

# ============================================================
# Logging
# ============================================================
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
